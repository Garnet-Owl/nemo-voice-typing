<Application x:Class="VoiceTyping.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ContextMenu x:Key="TrayMenu">
                <MenuItem Header="Show panel" Click="OnShowPanel"/>
                <MenuItem Header="Toggle dictation" Click="OnToggleDictation"/>
                <Separator/>
                <MenuItem Header="Start with Windows"
                          x:Name="StartupMenu"
                          IsCheckable="True"
                          Click="OnStartupToggle"/>
                <Separator/>
                <MenuItem Header="Exit" Click="OnExit"/>
            </ContextMenu>
            <tb:TaskbarIcon x:Key="TrayIcon"
                            ToolTipText="Nemo Voice Typing — Ctrl+Alt+A"
                            ContextMenu="{StaticResource TrayMenu}"
                            TrayLeftMouseUp="OnTrayLeftClick"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
