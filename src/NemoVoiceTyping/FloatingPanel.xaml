<Window x:Class="NemoVoiceTyping.FloatingPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nemo Voice Typing"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <SolidColorBrush x:Key="PillBg" Color="#F01A1B22"/>
        <SolidColorBrush x:Key="PillStroke" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="MicIdle" Color="#6A5CFF"/>
        <SolidColorBrush x:Key="MicActive" Color="#E25C5C"/>
        <SolidColorBrush x:Key="BarBrush" Color="#CC6A5CFF"/>
    </Window.Resources>

    <Border CornerRadius="18"
            Background="{StaticResource PillBg}"
            BorderBrush="{StaticResource PillStroke}"
            BorderThickness="1"
            Padding="8,5"
            MouseLeftButtonDown="OnDragBegin"
            MouseRightButtonUp="OnRightClick">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.45" Color="Black"/>
        </Border.Effect>
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Hide panel" Click="OnHide"/>
                <Separator/>
                <MenuItem Header="Exit" Click="OnExit"/>
            </ContextMenu>
        </Border.ContextMenu>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Button x:Name="MicButton"
                    Width="28" Height="28"
                    Background="{StaticResource MicIdle}"
                    BorderThickness="0"
                    Foreground="White"
                    Cursor="Hand"
                    Click="OnMicClick"
                    ToolTip="Toggle (Ctrl+Alt+A)">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock Text="🎤" FontSize="13" Margin="0,-1,0,0"/>
            </Button>

            <StackPanel x:Name="Bars" Orientation="Horizontal" Margin="10,0,4,0" VerticalAlignment="Center">
                <Rectangle x:Name="Bar0" Width="3" Height="4" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource BarBrush}"/>
                <Rectangle x:Name="Bar1" Width="3" Height="4" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource BarBrush}"/>
                <Rectangle x:Name="Bar2" Width="3" Height="4" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource BarBrush}"/>
                <Rectangle x:Name="Bar3" Width="3" Height="4" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource BarBrush}"/>
                <Rectangle x:Name="Bar4" Width="3" Height="4" Margin="2,0" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource BarBrush}"/>
            </StackPanel>

            <TextBlock x:Name="LoadingText"
                       Text=""
                       Foreground="#CCFFFFFF"
                       FontSize="10"
                       Margin="6,0,2,0"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
